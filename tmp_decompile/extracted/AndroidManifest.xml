<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.telr.android.payment.sdk" >

    <uses-sdk android:minSdkVersion="21" />

    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PaymentSDK"
        tools:targetApi="31" >
        <activity
            android:name="com.telr.android.payment.sdk.ui.paymentoptions.PaymentOptionsActivity"
            android:exported="true"
            android:theme="@style/Theme.PaymentSDK" >
        </activity>
        <activity
            android:name="com.telr.android.payment.sdk.flow.PaymentFlowActivity"
            android:exported="true"
            android:theme="@style/Theme.PaymentSDK" />
        <activity android:name="com.telr.android.payment.sdk.ui.threeds.ThreeDSActivity" />
        <activity android:name="com.telr.android.payment.sdk.ui.terms.TermsAndConditionsActivity" />
    </application>

</manifest>