<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <!-- Top row: Scheme icon, masked PAN, expiry, radio -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp">

            <ImageView
                android:id="@+id/schemeIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/app_name" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/maskedPan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="normal"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:text="" />

            <TextView
                android:id="@+id/expiry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="17sp" />
        </LinearLayout>

        <RadioButton
            android:id="@+id/radio"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:button="@null"
            android:background="@drawable/checkbox_circle_selector"
            android:contentDescription="@string/app_name" />
    </LinearLayout>

    <!-- Expanded section: CVV + Pay button (visible when selected) -->
    <LinearLayout
        android:id="@+id/expandedSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/cvvInput"
                android:layout_width="96dp"
                android:layout_height="44dp"
                android:background="@drawable/input_background"
                android:gravity="start|center_vertical"
                android:paddingStart="15dp"
                android:paddingEnd="10dp"
                android:textAlignment="viewStart"
                android:textSize="14sp"
                android:inputType="numberPassword"
                android:digits="0123456789"
                android:maxLength="4"
                android:hint="@string/newcard_placeholder_cvv"
                android:textColor="@color/text_input"
                android:textColorHint="@color/text_hint"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/payButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:background="@drawable/rounded_corners_button"
                android:elevation="0dp"
                android:stateListAnimator="@null"
                android:text="@string/pay"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textAllCaps="false" />

            <ImageButton
                android:id="@+id/deleteButton"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/delete_saved_card_action"
                android:scaleType="centerInside"
                android:src="@drawable/ic_trash"
                android:tint="@color/text_secondary"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/cvvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:text=""
            android:layout_marginTop="6dp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
